# App runtime state that used to bleed into this repo when config/ was
# symlinked wholesale to ~/.config/
config/chromium
config/gh
config/hub
config/octave
config/spotify
config/Trolltech.conf
config/Bitwarden

# At the repo root, `.local` files are created by `set_local_dotfiles`
# (symlinks from local/<env>/*). They must never be committed at the root.
# Anchored to root so the real sources at local/<env>/*.local stay tracked.
/*.local
/*.private
